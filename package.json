{
  "name": "github-webhook-bridge",
  "version": "2.0.0",
  "description": "Receive and parse GitHub Webhooks and send messages to Discord, providing a more flexible notification system with enhanced integration between GitHub and Discord.",
  "homepage": "https://github.com/book000/github-webhook-bridge",
  "bugs": {
    "url": "https://github.com/book000/github-webhook-bridge/issues"
  },
  "license": "MIT",
  "author": "Tomachi [ICHIGO] <tomachi@tomacheese.com>",
  "private": true,
  "main": "index.js",
  "repository": {
    "url": "git@github.com:book000/github-webhook-bridge.git",
    "type": "git"
  },
  "scripts": {
    "start": "tsx ./src/main.ts",
    "dev": "tsx watch ./src/main.ts",
    "vercel": "vercel dev",
    "build": "tsc -p tsconfig.json",
    "lint:prettier": "prettier --check src",
    "lint:tsc": "tsc",
    "fix:eslint": "eslint . -c eslint.config.mjs --fix",
    "fix:prettier": "prettier --write src",
    "test": "jest --runInBand --passWithNoTests --detectOpenHandles --forceExit",
    "preinstall": "npx only-allow pnpm",
    "lint": "run-z lint:prettier,lint:eslint,lint:tsc",
    "lint:eslint": "eslint . -c eslint.config.mjs",
    "fix": "run-z fix:prettier,fix:eslint"
  },
  "devDependencies": {
    "@book000/eslint-config": "1.15.4",
    "@book000/node-utils": "1.24.242",
    "@fastify/cors": "11.2.0",
    "@octokit/webhooks-examples": "7.6.1",
    "@octokit/webhooks-types": "7.6.1",
    "@types/diff": "8.0.0",
    "@types/jest": "30.0.0",
    "@types/node": "24.13.2",
    "@vercel/node": "5.8.17",
    "diff": "9.0.0",
    "eslint": "10.5.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "18.1.0",
    "eslint-plugin-promise": "7.3.0",
    "fastify": "5.8.5",
    "fastify-raw-body": "5.0.0",
    "jest": "30.4.2",
    "jest-expect-message": "1.1.3",
    "jsonc-parser": "3.3.1",
    "prettier": "3.8.4",
    "run-z": "2.1.0",
    "ts-jest": "29.4.11",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "jest": {
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "testMatch": [
      "**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "setupFilesAfterEnv": [
      "jest-expect-message"
    ]
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "engines": {
    "node": "24.18.0"
  }
}
